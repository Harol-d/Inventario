<Window x:Class="Inventario.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inventario"
        mc:Ignorable="d"
        Title="Inventario" Height="527" Width="866">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Name="dgProductos" Grid.Row="0" 
              AutoGenerateColumns="False"
                  CanUserAddRows="False"
              Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn />
                <DataGridTextColumn Header="ID" Binding="{Binding Path=id}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="PRODUCTO" Binding="{Binding Path=nombre}" Width="*" IsReadOnly="True"/>
                <DataGridTextColumn Header="CANTIDAD" Binding="{Binding Path=cantidad}" Width="Auto" IsReadOnly="True"/>
                <DataGridTextColumn Header="PRECIO" Binding="{Binding Path=precio}" Width="Auto" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <DockPanel Grid.Row="1" LastChildFill="False" Margin="0,10,0,0">

            <Label Content="" Name="cantidadProductos" DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button Content="Agregar" Width="80" Click="AgregarProducto"/>
                <Button Content="" Width="80" Margin="5,0"/>
                <!--Button Content="Editar" Width="80" Click="Button_Click"/>-->
            </StackPanel>

        </DockPanel>
    </Grid>
</Window>
