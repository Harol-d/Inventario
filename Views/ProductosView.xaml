<Window x:Class="Inventario.Views.ProductosView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Inventario.Views"
        mc:Ignorable="d"
        Title="ProductosView" Height="450" Width="800">
    <!-- Contenedor del Modal (Ponlo al final de tu Grid principal para que flote encima) -->
    <Grid x:Name="ContenedorModal" Visibility="Collapsed">
        <!-- Fondo oscuro traslúcido -->
        <Border Background="#CC000000"  />

        <!-- Tarjeta del Modal -->
        <Border Background="White" 
            CornerRadius="12" 
            Width="350" 
            HorizontalAlignment="Center" 
            VerticalAlignment="Center"
            Padding="25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Detalles del Producto" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20" 
                       Foreground="#333"/>

                <!-- Campo: Nombre -->
                <TextBlock Text="Nombre del artículo" Foreground="Gray" Margin="0,0,0,5"/>
                <TextBox x:Name="txtNombre" Padding="8" Margin="0,0,0,15"/>

                <!-- Fila para Cantidad y Precio (Lado a lado) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <!-- Espacio entre columnas -->
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Campo: Cantidad -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Cantidad" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtCantidad" Padding="8"/>
                    </StackPanel>

                    <!-- Campo: Precio -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Precio ($)" Foreground="Gray" Margin="0,0,0,5"/>
                        <TextBox x:Name="txtPrecio" Padding="8"/>
                    </StackPanel>
                </Grid>

                <!-- Botones de Acción -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                    <Button Content="Cancelar" 
                        Width="80" 
                        Height="35" 
                        Background="Transparent" 
                        BorderBrush="LightGray"
                        Margin="0,0,10,0"/>

                    <Button Content="Guardar" 
                        Width="100" 
                        Height="35" 
                        Background="#007ACC" 
                        Foreground="White"
                        FontWeight="SemiBold">
                        <Button.Resources>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
